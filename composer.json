{
    "name": "maispace/environment",
    "description": "This extension provides enviroment depended helper functions for setting up TYPO3",
    "type": "typo3-cms-extension",
    "license": [
        "GPL-2.0-or-later"
    ],
    "require": {
        "typo3/cms-core": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "typo3/testing-framework": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\Environment\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\Environment\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "environment"
        }
    }
}
